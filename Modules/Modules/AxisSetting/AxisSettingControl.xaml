<UserControl x:Class="Modules.AxisSettingControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Modules"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">
    <ScrollViewer x:Name="control"
                  Loaded="LoadedCommand"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel Orientation="Vertical">
            <ItemsControl ItemsSource="{Binding AxisSettingUIUseClasses}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <local:AxisSetting Axis="{Binding Axis}"
                                           AxisConfig="{Binding AxisConfig}"
                                           LockAxis="{Binding LockAxis}"
                                           IsReverse="{Binding IsReverse}"
                                           HomeAction="{Binding HomeAction}"></local:AxisSetting>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
